# ── Telegram Bot (from @BotFather) ───────────────────────────────────────────
BOT_TOKEN=your_telegram_bot_token_here

# ── Telegram MTProto API (from https://my.telegram.org) ──────────────────────
# Required to READ from public channels as a user client
# Use a DEDICATED account/SIM — never your personal number
API_ID=your_api_id_here
API_HASH=your_api_hash_here
PHONE_NUMBER=+27xxxxxxxxx   # The number of the dedicated account

# ── Your HORMUZ channel ───────────────────────────────────────────────────────
# The channel where aggregated posts will be sent
# Use the @username (without @) or numeric ID (e.g. -1001234567890)
TARGET_CHANNEL=StateOfHormuzBot   # Replace with your actual channel @username

# ── Optional: minimum interval between posts (seconds) ───────────────────────
MIN_POST_INTERVAL=30

AISSTREAM_API_KEY=your_aisstream_api_key_here

# ── Pre-launch daily rotation (Phase 2 “where to be” + 3 post types) ───────────
# 1×/day Telegram at PRELAUNCH_DAILY_HOUR UTC; rotates news / build / meme copy.
# Drafts for X + Reddit land in outreach/social_drafts/ (post manually).
PRELAUNCH_DAILY_ENABLED=0
PRELAUNCH_DAILY_HOUR=12
PRELAUNCH_MIRROR_BLUESKY=0
PRELAUNCH_WRITE_DRAFTS=1
# BLUESKY_PROFILE_URL=https://bsky.app/profile/your.handle.bsky.social