# Copy to .env.local — never commit secrets

NEXT_PUBLIC_SITE_URL=https://hormuz.live
NEXT_PUBLIC_CLUSTER=devnet
NEXT_PUBLIC_RPC_URL=https://api.devnet.solana.com
NEXT_PUBLIC_PROGRAM_ID=
NEXT_PUBLIC_HORMUZ_MINT=

# Mainnet transparency (Rug-proof card) — override if deployment changes
# NEXT_PUBLIC_PROOF_LP_LOCK_TX_URL=https://solscan.io/tx/...
# NEXT_PUBLIC_PROOF_LP_FEE_NFT_URL=https://solscan.io/token/...
# NEXT_PUBLIC_PROOF_POOL_URL=https://solscan.io/account/...
# NEXT_PUBLIC_PROOF_VEST_URL=https://app.streamflow.finance/mainnet/vesting/...  (when team vest is live)

# Optional — Strait Monitor live AIS (same keys must be set on Vercel for production)
# AISSTREAM_API_KEY=
# AISHUB_USERNAME=

# Optional: canonical link hub (defaults to https://stateofhormuz.org)
# NEXT_PUBLIC_LINK_HUB_URL=https://stateofhormuz.org

# Optional: public GitHub repo — shown in Rug-proof card (“this repo powers the dApp”)
# NEXT_PUBLIC_GITHUB_REPO_URL=https://github.com/your-org/hormuz

# Optional: Strait Monitor diagnostics (browser + server; dev mode also enables these)
# NEXT_PUBLIC_MONITOR_DEBUG=1
# MONITOR_API_DEBUG=1
